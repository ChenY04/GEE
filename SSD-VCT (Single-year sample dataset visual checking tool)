var dis_ndvi_button = ui.Button({
  label:'Show',
  style: Label_style,
  onClick:function(){
    var number = ee.Number.parse(app.data.vali_index);
    var feature = ee.Feature(app.data.vali_list.get(number)).geometry();
    
    down_right_panel.clear();
    
    function maskS2clouds(image) {
      var qa = image.select('QA60');
      var cloudBitMask = 1 << 10;
      var cirrusBitMask = 1 << 11;
      var mask = qa.bitwiseAnd(cloudBitMask).eq(0).and(qa.bitwiseAnd(cirrusBitMask).eq(0));
      return image.updateMask(mask).divide(10000).copyProperties(image, ['system:time_start', 'system:time_end']);
    }
    
    var targetYear = parseInt(app.data.target_year);
    var step = parseInt(app.data.step_year);
    var nextYearStr = (targetYear + 1).toString();
    
    // 1. 为支持后端合成，扩大 S2 集合拉取范围： [targetYear - step] 到 [targetYear + step] + 次年1月
    var startYearStr = (targetYear - step).toString();
    var endYearStr = (targetYear + step + 1).toString(); 
    
    var S2_Collect = ee.ImageCollection('COPERNICUS/S2_SR_HARMONIZED')
      .filterBounds(feature)
      .filterDate(startYearStr + '-01-01', endYearStr + '-01-31')
      .map(maskS2clouds);
      
    // 2. 将显示限制回调至“单一完整周期 (目标年12个月 + 次年1个月)”
    var isLeap = (targetYear % 4 === 0 && targetYear % 100 !== 0) || (targetYear % 400 === 0);
    var totalExtendedDays = (isLeap ? 366 : 365) + 31; 
    
    var range = ee.Number(totalExtendedDays); 
    var end_index = range.divide(app.data.slide_window).int();
    
    var x_axis = ee.List.sequence(0, end_index).map(function(j){
      return ee.Number(j).multiply(app.data.slide_window);
    });

    var febDays = isLeap ? 29 : 28;
    var monthDays = [31, febDays, 31, 30, 31, 30, 31, 31, 30, 31, 30, 31, 31]; 
    
    var monthTicks = [];
    var currentDay = 0;
    for (var m = 1; m <= 13; m++) { 
      var displayMonth = m;
      var displayYear = targetYear;
      if (m === 13) {
        displayMonth = 1; 
        displayYear = targetYear + 1;
      }
      var monthStr = (displayMonth < 10 ? '0' : '') + displayMonth;
      // 保持 YY-MM 刻度，让图表末尾清楚看到跨入了下一年
      monthTicks.push({v: currentDay, f: monthStr}); 
      currentDay += monthDays[m - 1];
    }
    
    var indices = ['NDVI', 'SWIR1', 'OSAVI', 'TCARI'];
    
    indices.forEach(function(indexName) {
      // 传入 step 参与底层影像运算合并
      var actual_list = curveUtils.MVC(app.data.target_year, S2_Collect, app.data.slide_window, feature, app.data.step_year, indexName);
      var sg_list = sg_fitting.ndvi_sg(actual_list, feature);
      var all_values = ee.Array.cat([actual_list, actual_list, sg_list], 1);
      
      var chart = ui.Chart.array.values(all_values, 0, x_axis)
        .setSeriesNames(['Actual value', 'Line chart', 'Savitzky-Golay fitting']).setOptions({
          title: 'Composite ' + indexName + ' (Step: ' + step + ' Yrs) | View: ' + app.data.target_year + ' ~ ' + nextYearStr + '-01',
          hAxis: {
            title: 'Time',
            ticks: monthTicks,
            viewWindow: { min: 0, max: totalExtendedDays } 
          }, 
          vAxis: {title: 'Sample ' + app.data.vali_index + ' ' + indexName},
          legend: null,
          series: { 
            0:{ lineWidth: 0, pointSize: 3},
            1: { lineWidth: 1,pointSize: 0, color: 'orange'},
            2: { lineWidth: 2, pointSize: 0, color: 'red' }
          }
        });
      down_right_panel.add(chart);
    });
  
   // 3. 降水图表 (CHIRPS) 仅呈现目标年实际降水，不参与邻近年合成
    var startDate = app.data.target_year + '-01-01';
    var endDate = nextYearStr + '-01-31'; 
    
    var chirps = ee.ImageCollection("UCSB-CHC/CHIRPS/V3/DAILY_RNL")
      .filterBounds(feature)
      .filterDate(startDate, ee.Date(endDate).advance(1, 'day'))
      .select('precipitation')
      .map(function(img) {
        return img.unmask(0).copyProperties(img, ['system:time_start']);
      });
      
    var precipChart = ui.Chart.image.series({
      imageCollection: chirps,
      region: feature,
      reducer: ee.Reducer.mean(),
      scale: 5000, 
      xProperty: 'system:time_start'
    }).setOptions({
      title: 'Real Daily Precipitation (CHIRPS) in ' + app.data.target_year,
      hAxis: {title: 'Time (Daily)', format: 'YY-MM-dd'}, 
      vAxis: {title: 'Precipitation (mm)', viewWindow: {min: 0}},
      colors: ['#0000FF'],
      lineWidth: 1,
      pointSize: 2,
      legend: {position: 'none'}
    });
    
    down_right_panel.add(precipChart);
  }
});

