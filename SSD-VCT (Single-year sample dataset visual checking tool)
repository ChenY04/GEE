var visualization = {min: 0.0, max: 0.3, bands: ['RED', 'GREEN', 'BLUE']}

function displayBrowseImg(sentinel_dataset, aoiBox, aoiCircle){
  var RGB_PARAMS = {bands: [app.data.selectb1,app.data.selectb2,app.data.selectb3], min:0.0, max:0.3}
  
  // Sentinel-2 均值影像 Display
  var sentinel_img = sentinel_dataset.mean() 
  var aoiImg = ee.Image().byte()
    .paint(ee.FeatureCollection(ee.Feature(aoiCircle)), 2, 5)
    .visualize({palette: AOI_COLOR});
    
  var sentinel_thumbnail = ui.Thumbnail({
    image: sentinel_img.visualize(visualization).blend(aoiImg),
    params: {region: aoiBox, dimensions: '200', crs: 'EPSG:3857', format: 'PNG'}
  });
  
  var Sentinel_Card = ui.Panel([ui.Label('Sentinel-2 Mean',
    {margin: '4px 4px -6px 8px', fontSize: '13px', fontWeight: 'bold'}),
    sentinel_thumbnail], null, {margin: '4px 0px 0px 4px' , width: 'px'});
  right_panel.add(Sentinel_Card);
  
  // ================= 2. 增加 Sentinel-1 VH Entropy 显示 =================
  // 获取目标年内 Sentinel-1 VH 集合
  var s1_col = ee.ImageCollection('COPERNICUS/S1_GRD')
    .filterBounds(aoiBox)
    .filterDate(app.data.target_year + '-01-01', app.data.target_year + '-12-31')
    // .filter(ee.Filter.listContains('transmitterReceiverPolarisation', 'VH'))
    .filter(ee.Filter.eq('instrumentMode', 'IW'))
    // .select('VH');

  // 获取年度最大值，并裁剪到可视窗口（极大提高计算效率）
  // var s1_vh_max = s1_col.select('VH').max().clip(aoiBox);
  var s1_vh_max = s1_col.select('VH').max();

  // 将 dB 值 (通常在 -30 到 0 之间) 映射为非负整型，满足 GLCM 函数要求
  // 例如：-20dB -> (-20 + 30) * 10 = 100
  var s1_int = s1_vh_max.clamp(-25, -5)   // 截断异常极端值
                 .subtract(-25)           // 将最小值平移到 0
                 .divide(20)              // 归一化到 0~1
                 .multiply(32)            // 扩展为 32 个灰度级
                 .toInt();                // 转为整型

  // 计算 GLCM 纹理并专门提取 Entropy (熵)，邻域窗口设为 3 (7x7像素)
  var vh_entropy = s1_int.glcmTexture({size: 3}).select('VH_ent');
  
  var ent_stats = vh_entropy.reduceRegion({
    reducer: ee.Reducer.percentile([2, 98]),
    geometry: aoiBox,
    scale: 10,
    maxPixels: 1e6
  });
  var ent_min = ee.Number(ent_stats.get('VH_ent_p2'));
  var ent_max = ee.Number(ent_stats.get('VH_ent_p98'));
  
  var diff = ent_max.subtract(ent_min);
  ent_max = ee.Algorithms.If(diff.lt(0.5), ent_min.add(2.0), ent_max);
  ent_min = ee.Algorithms.If(diff.lt(0.5), ent_min.subtract(1.0), ent_min);
  var stretched_ent = vh_entropy.unitScale(ent_min, ent_max).clamp(0, 1);
  
  // 设置可视化参数 (自然状态下农田纹理的熵值一般落在 0~5 的区间)
  // var ent_vis = {min: 0, max: 6, palette: ['black', 'yellow', 'red']};
  var ent_vis = {min: 0, max: 1, palette: ['black', 'yellow', 'red']};
  
  var s1_thumbnail = ui.Thumbnail({
    image: stretched_ent.visualize(ent_vis).blend(aoiImg),
    params: {region: aoiBox, dimensions: '200', crs: 'EPSG:3857', format: 'PNG'}
  });

  var S1_Ent_Card = ui.Panel([ui.Label('Sentinel-1 VH Entropy',
    {margin: '4px 4px -6px 8px', fontSize: '13px', fontWeight: 'bold'}),
    s1_thumbnail], null, {margin: '4px 0px 0px 4px' , width: 'px'});
  right_panel.add(S1_Ent_Card);
  
// ================= 2.5 增加 Sentinel-1 假彩色 (False Color) 显示 =================
