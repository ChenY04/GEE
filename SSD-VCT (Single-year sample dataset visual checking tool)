/* used for the SSD_VCT tool  */
var sg_indice = require('users/yourset/Algorithms:vi_sg');

/** 提取 Sentinel-2 每个时间窗口内的最大指数合成值 (支持跨年份合成) */
function s2list_indice(select_s2, year_num, index, slidewindow, point, str_indice, step){
  index = ee.Number(index);
  step = ee.Number(step);
  var start = ee.Number(index.multiply(slidewindow));
  var end = ee.Number(index.add(1).multiply(slidewindow));
  
  // 生成前后邻近年份的偏移列表，例如 step=1 时生成 [-1, 0, 1]
  var stepList = ee.List.sequence(step.multiply(-1), step);
  
  // 核心逻辑：遍历偏移年份，分别提取相同滑动窗口(DOY)的数据并合并
  var multiYearCol = ee.ImageCollection(
    stepList.iterate(function(offset, prevCol) {
      var currentYear = ee.Number(year_num).add(offset);
      var baseDate = ee.Date.fromYMD(currentYear, 1, 1);
      var start_date = baseDate.advance(start, 'day');
      var end_date = baseDate.advance(end, 'day');
      var currentYearCol = select_s2.filterDate(start_date, end_date);
      return ee.ImageCollection(prevCol).merge(currentYearCol);
    }, ee.ImageCollection([]))
  );
  
  // 计算指定的四个指数
  var select_s2_final = multiYearCol.map(function(img){
    var img_nir = img.select('B8');
    var img_red = img.select('B4');
    var img_green = img.select('B3');
    var img_re1 = img.select('B5');
    var img_swir1 = img.select('B11');
    
    var ndvi = img.normalizedDifference(['B8', 'B4']).toDouble().rename('NDVI');
    var swir1 = img_swir1.toFloat().rename('SWIR1');
    var osavi = img.expression("1.16*(nir-red)/(nir+red+0.16)", 
      { "nir": img_nir, "red": img_red}).float().rename("OSAVI");
    var tcari = img.expression("3*((re1-red)-0.2*(re1-green)*re1/red)", 
      { "re1": img_re1, "red": img_red, "green": img_green}).float().rename("TCARI");
      
    return img.addBands([ndvi, swir1, osavi, tcari]).select([str_indice]);
  });
  
  // 追加带默认波段的 Dummy Image，防止当前窗口在所有年份都无有效影像导致报错
  var dummyImage = ee.Image.constant(-9999).rename(str_indice).updateMask(0);
  var collectionWithDummy = select_s2_final.merge(ee.ImageCollection([dummyImage]));
  var max_img = collectionWithDummy.max();
  
  // 使用 reduceRegion 安全提取像素值
  var dict = max_img.reduceRegion({
    reducer: ee.Reducer.first(),
    geometry: point,
    scale: 10
  });
  
  var val = dict.get(str_indice);
  var news2max = ee.Number(ee.Algorithms.If(ee.Algorithms.IsEqual(val, null), -9999, val));
  return news2max;
}

/** MVC 提取函数 */
exports.MVC = function (year_num, img_s2, slideWindow, point, step, str_indice){
  year_num = ee.Number(parseInt(year_num, 10));
  step = ee.Number(parseInt(step, 10));
  
  // 判断目标年份是否为闰年
  var isLeap = ee.Algorithms.If(
    ee.Number(year_num).mod(4).eq(0).and(ee.Number(year_num).mod(100).neq(0)).or(ee.Number(year_num).mod(400).eq(0)), 
    366, 365
  );
  
  // X轴范围仅保留：目标年全年 + 次年1月份 (31天)
  var range = ee.Number(isLeap).add(31); 
  var slidewindow = ee.Number(slideWindow);  
  var end_index = range.divide(slidewindow).int();
  
  var ini_indice_list = ee.List.sequence(0, end_index);
  
  var raw_list = ini_indice_list.map(function(index) {
      // 传递 step 参数进入合成提取流程
      return s2list_indice(img_s2, year_num, index, slidewindow, point, str_indice, step);
  });
  
  // 空缺值线性插值
  var indice_list = ini_indice_list.map(function(index){
      index = ee.Number(index);
      var val = ee.Number(raw_list.get(index));
      var prev = ee.Algorithms.If(index.gt(0), raw_list.get(index.subtract(1)), val);
      var next = ee.Algorithms.If(index.lt(end_index), raw_list.get(index.add(1)), val);
      
      prev = ee.Algorithms.If(ee.Number(prev).neq(-9999), prev, 0);
      next = ee.Algorithms.If(ee.Number(next).neq(-9999), next, 0);
      
      var interpolation = ee.Number(prev).add(ee.Number(next)).divide(2);
      var max = ee.Number(ee.Algorithms.If(val.eq(-9999), interpolation, val));
      
      return ee.Algorithms.If(max.eq(-9999), 0, max);
  });
  
  return indice_list;
}

