function addPointAt(coords){
  var propName = classPropNameTxt.getValue() || 'class'
  var propVal  = classPropValTxt.getValue()
  var geom = ee.Geometry.Point([coords.lon, coords.lat])
  var feat = ee.Feature(geom)
              .set(propName, propVal)
              .set('user_added', true)
              .set('added_time', ee.Date(Date.now()).format())
  currentFC = ee.FeatureCollection([feat]).merge(currentFC)
  actionHistory.push({type:'add', feature: feat})
  refreshLayer()
}

function deleteNearestAt(coords){
  var tol = parseFloat(tolTxt.getValue() || '50')
  var clickPt = ee.Geometry.Point([coords.lon, coords.lat])
  var withDist = currentFC.map(function(f){
    return f.set('tmp_dist', f.geometry().distance(clickPt))
  })
 
  var nearest = ee.Feature(withDist.sort('tmp_dist').first())
  var nearestDist = ee.Number(nearest.get('tmp_dist'))
  nearestDist.evaluate(function(d){
    if (d == null){ notify('No feature found.', 'orange'); return }
    if (d > tol){
      notify('No point within tolerance of ' + tol + ' m (nearest: ' + Math.round(d) + ' m).', 'orange');
      return
    }
    var sid = ee.String(nearest.get('system:index'))
    currentFC = currentFC.filter(ee.Filter.neq('system:index', sid))
    actionHistory.push({type:'delete', feature: nearest})
    refreshLayer()
  })
}

function undoLast(){
  if (actionHistory.length === 0){
    notify('Nothing to undo.', 'orange');
    return
  }
  var last = actionHistory.pop()
  if (last.type === 'add'){
    var geom = ee.Geometry(last.feature.geometry())
    var pName = classPropNameTxt.getValue() || 'class'
    var pVal  = last.feature.get(pName)
    var withDist = currentFC.map(function(f){
      return f.set('tmp_dist', f.geometry().distance(geom))
    })
    var candidate = ee.Feature(withDist
                    .filter(ee.Filter.eq(pName, pVal))
                    .sort('tmp_dist')
                    .first())
    var cid = ee.String(candidate.get('system:index'))
    currentFC = currentFC.filter(ee.Filter.neq('system:index', cid))
  } else if (last.type === 'delete'){
    currentFC = ee.FeatureCollection([last.feature]).merge(currentFC)
  }
  refreshLayer()
}

